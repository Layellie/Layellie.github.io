          },
          "tr": {
            "label": "Timer Çözünürlüğü",
            "status": "Kilitli"
          },
          "en": {
            "label": "Timer Resolution",
            "status": "Locked"
          }
        },
        {
          "id": "timer-memory",
          "type": "statCard",
          "shared": {
            "placement": {
              "mobileColSpan": 6,
              "desktopColSpan": 6,
              "rowSpan": 1,
              "height": "normal"
            },
            "icon": "MemoryStick",
