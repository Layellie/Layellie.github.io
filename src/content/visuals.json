{
  "schemaVersion": 1,
  "presets": [
    {
      "id": "clipboard",
      "name": "AIO Hybrid Clipboard",
      "shared": {
        "accent": "lime",
        "window": {
          "title": "AIO Hybrid Clipboard",
          "icon": "ClipboardList",
          "controls": "neutral",
          "trailing": "ALT + SPACE"
        },
        "footer": {
          "icon": "Code2",
          "badge": "Reverse Search"
        }
      },
      "tr": {
        "footerText": "OCR Motoru · C++20 / WinRT",
        "footerBadge": "Tersine Arama"
      },
      "en": {
        "footerText": "OCR Engine · C++20 / WinRT",
        "footerBadge": "Reverse Search"
      },
      "modules": [
        {
          "id": "clipboard-search",
          "type": "searchBar",
          "shared": {
            "placement": {
              "mobileColSpan": 12,
              "desktopColSpan": 12,
              "rowSpan": 1,
              "height": "normal"
            },
            "icon": "Search"
          },
          "tr": {
            "placeholder": "Pano geçmişinde ara…"
          },
          "en": {
            "placeholder": "Search clipboard history…"
          }
        },
        {
          "id": "clipboard-row-code",
          "type": "listRow",
          "shared": {
            "placement": {
              "mobileColSpan": 12,
              "desktopColSpan": 12,
              "rowSpan": 1,
              "height": "normal"
            },
            "index": "1",
            "icon": "Code2",
            "shortcut": "ALT+1",
            "tone": "code"
          },
          "tr": {
            "text": "git commit -m \"perf: 0.5ms timer\"",
            "caption": ""
          },
          "en": {
            "text": "git commit -m \"perf: 0.5ms timer\"",
            "caption": ""
          }
        },
        {
          "id": "clipboard-row-ocr",
          "type": "listRow",
          "shared": {
            "placement": {
              "mobileColSpan": 12,
              "desktopColSpan": 12,
              "rowSpan": 1,
              "height": "normal"
            },
            "index": "2",
            "icon": "Image",
            "shortcut": "ALT+2",
            "badge": "OCR",
            "tone": "image"
          },
          "tr": {
            "text": "Fatura No: 2026-0192",
            "caption": "görselden çıkarılan metin"
          },
          "en": {
            "text": "Invoice No: 2026-0192",
            "caption": "text extracted from image"
          }
        },
        {
          "id": "clipboard-row-link",
          "type": "listRow",
          "shared": {
            "placement": {
              "mobileColSpan": 12,
              "desktopColSpan": 12,
              "rowSpan": 1,
              "height": "normal"
            },
            "index": "3",
            "icon": "Link2",
            "shortcut": "ALT+3",
            "tone": "code"
          },
          "tr": {
            "text": "github.com/Layellie",
            "caption": ""
          },
          "en": {
            "text": "github.com/Layellie",
            "caption": ""
          }
        }
      ]
    },
    {
      "id": "standby",
      "name": "StandbyAndTimer",
      "shared": {
        "accent": "lime",
        "window": {
          "title": "StandbyAndTimer",
          "icon": "Gauge",
          "controls": "neutral",
          "trailing": "Admin",
          "trailingIcon": "Lock"
        },
        "footer": {
          "icon": "Cpu",
          "badge": "MVVM"
        }
      },
      "tr": {
        "windowTrailing": "Yönetici",
        "footerText": "NtSetTimerResolution · Win32 P/Invoke",
        "footerBadge": "MVVM"
      },
      "en": {
        "windowTrailing": "Admin",
        "footerText": "NtSetTimerResolution · Win32 P/Invoke",
        "footerBadge": "MVVM"
      },
      "modules": [
        {
          "id": "timer-resolution",
          "type": "metric",
          "shared": {
            "placement": {
              "mobileColSpan": 12,
              "desktopColSpan": 12,
              "rowSpan": 1,
              "height": "normal"
            },
            "value": "0.50",
