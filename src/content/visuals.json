            "progress": 82
          },
          "tr": {
            "label": "Standby Bellek",
            "caption": "temizlendi"
          },
          "en": {
            "label": "Standby Memory",
            "caption": "cleared"
          }
        },
        {
          "id": "timer-game-mode",
          "type": "toggle",
          "shared": {
            "placement": {
              "mobileColSpan": 6,
              "desktopColSpan": 6,
              "rowSpan": 1,
              "height": "normal"
            },
            "icon": "Gamepad2",
            "enabled": true
          },
          "tr": {
            "label": "Oyun Modu",
            "valueLabel": "Açık",
            "caption": "Yüksek öncelik · Tam affinity"
          },
          "en": {
            "label": "Game Mode",
            "valueLabel": "On",
            "caption": "High priority · Full affinity"
          }
        }
      ]
    },
