# Local development only. Copy to worker/.dev.vars and replace placeholders.
# Never commit worker/.dev.vars.
GITHUB_CLIENT_ID=REPLACE_WITH_GITHUB_APP_CLIENT_ID
GITHUB_CLIENT_SECRET=REPLACE_WITH_GITHUB_APP_CLIENT_SECRET
GITHUB_OWNER=Layellie
GITHUB_REPOSITORY=Layellie.github.io
GITHUB_DEFAULT_BRANCH=main
GITHUB_ALLOWED_USER=Layellie
GITHUB_ALLOWED_USER_ID=REPLACE_WITH_NUMERIC_GITHUB_USER_ID
SESSION_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
ADMIN_ORIGIN=http://localhost:5174
PUBLIC_SITE_ORIGIN=https://layellie.github.io
